# ========== 腾讯云镜像仓库 ==========
TCR_REGISTRY=ccr.ccs.tencentyun.com
NAME_SPACE=your-namespace
REPO=ffmpeg-mcp
IMAGE_TAG=latest

# ========== 服务配置 ==========
MCP_PORT=8032
MCP_EXTERNAL_URL=http://your-server-ip:8032
MCP_AUTH_TOKEN=your-auth-token

# ========== 数据目录 ==========
VIDEOS_DIR=./videos
OUTPUT_DIR=./output
